  "components": {
    "schemas": {
      "AddPurchaseOrderItemDto": {
        "type": "object",
        "properties": {
          "productID": {
            "type": "integer",
            "format": "int32"
          },
          "orderedQuantity": {
            "type": "integer",
            "format": "int32"
          },
          "unitPrice": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "ChangePasswordDto": {
        "required": [
          "newPassword",
          "oldPassword"
        ],
        "type": "object",
        "properties": {
          "oldPassword": {
            "minLength": 1,
            "type": "string"
          },
          "newPassword": {
            "minLength": 8,
            "pattern": "^(?=.*[a-z])(?=.*[A-Z])(?=.*\\d).+$",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "CreateBatchDto": {
        "type": "object",
        "properties": {
          "lotNumber": {
            "type": "string",
            "nullable": true
          },
          "expiryDate": {
            "type": "string",
